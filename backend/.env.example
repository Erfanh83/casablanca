# کپی این فایل به .env و مقادیر را پر کنید
DEBUG=True
SECRET_KEY=your-very-long-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Database (production)
DATABASE_URL=postgresql://user:password@localhost:5432/casablanca_db

# Admin panel URL slug (مخفی نگه دارید)
ADMIN_URL_SLUG=c4z4bl4nc4-x9k2

# JWT settings
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Media files
MEDIA_ROOT=media/
MAX_UPLOAD_SIZE_MB=5
